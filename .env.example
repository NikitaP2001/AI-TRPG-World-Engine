# IMPORTANT: set this to your actual model context window.
# If set too high, the app may keep too much history and the provider can reject requests.
# Examples: 8192, 16384, 32768, 65536
# LLM_WORLD_MODEL_CONTEXT_TOKENS=32768

# Fraction of model context reserved for persistent chat history (0..1).
# Default is 1.0 (history cap == model context window). Lower this if you inject
# large world context blocks or hit provider context errors.
# LLM_WORLD_HISTORY_FRACTION=1.0

# Safety cap: how many internal "ticks" the console will auto-run while waiting
# for a turn to finalize (prevents /continue from hanging forever).
# LLM_WORLD_AUTO_ADVANCE_MAX_STEPS=200

# If the GM keeps ticking but makes no observable world progress (time, scene iteration,
# story turns/paragraphs, etc.), bail out early with diagnostics instead of spinning.
# LLM_WORLD_NO_PROGRESS_MAX_STEPS=30

# Enable async paragraph/arc summarization worker (scene progress does not wait).
# Writes are guarded by per-file locks and compare-and-apply checks.
# LLM_WORLD_ASYNC_SUMMARY=1

# Reflection worker count (background, non-blocking for turn progression).
# LLM_WORLD_REFLECTION_WORKERS=2

# Cross-process file lock tuning (seconds) for world/story/facts and reflection files.
# LLM_WORLD_FILE_LOCK_TIMEOUT=30
# LLM_WORLD_FILE_LOCK_STALE_SECONDS=600

# Optional: disable SA plain-text word guard (0 = disabled)
# LLM_WORLD_SA_MAX_TEXT_WORDS=0
# LLM_WORLD_SA_MAX_TEXT_VIOLATIONS=3

# Throttle SA world-maintenance write tools in setup phase.
# Default is 10 (writes exposed every 10 completed turns). Set 1 to disable throttling.
# Copy to .env and fill in values.

# Required
# OPENROUTER_API_KEY=

# DeepSeek/OpenAI-compatible endpoint + model
OPENROUTER_BASE_URL=https://api.deepseek.com/v1
OPENROUTER_MODEL=deepseek-v4-flash
OPENROUTER_MODEL_SA=deepseek-v4-flash

# Runtime tuning
LLM_WORLD_SA_MAX_TEXT_WORDS=0
LLM_WORLD_ASYNC_SUMMARY=1
LLM_WORLD_LOG_API_REQUESTS=1
LLM_WORLD_HISTORY_FRACTION=0.75

# SA backend switch:
# - local      -> use local OpenAI-compatible server (Qwen2.5)
# - deepseek   -> use DeepSeek API endpoint
LLM_WORLD_SA_BACKEND=deepseek
# LLM_WORLD_SA_BACKEND=deepseek
# LLM_WORLD_SA_BACKEND=local
# LLM_WORLD_SA_LOCAL_MODEL=qwen2.5:14b-instruct
# LLM_WORLD_SA_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# LLM_WORLD_SA_LOCAL_API_KEY=local

# Logging (JSONL)
# - logs/runs.jsonl: all LLM + tool events
# - logs/tool_calls.jsonl: tool calls + params only
# - logs/model_outputs.jsonl: model outputs only (no prompts/inputs)
LLM_WORLD_LOGS_ENABLED=1

# Make logs minimal/readable by default. Set to 1 to include prompts/internal details.
LLM_WORLD_LOGS_VERBOSE=0

# Truncate long outputs/params for readability (applies to some log fields).
LLM_WORLD_LOG_TRUNCATE_CHARS=4000

# Optional: force fsync() after each log line (slower, but safest for crash/hang debugging)
LLM_WORLD_LOGS_FSYNC=0

# When logs are enabled, also print minimal trace lines to console
# (which agent responded; which tool was called; no params/prompts).
LLM_WORLD_CONSOLE_TRACE=1

# Optional OpenRouter metadata headers (if you decide to use them later)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
